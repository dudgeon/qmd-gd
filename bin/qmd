#!/usr/bin/env node
// Cross-platform launcher for qmd.
//
// Previously this was a POSIX shell script with `#!/bin/sh`, which meant npm
// on Windows generated shims that tried to route through `/bin/sh` — a path
// that doesn't exist on Windows, so `qmd` failed immediately after a global
// install. Rewriting the launcher in Node.js lets npm generate native
// cmd/ps1/sh shims that invoke `node` directly on every platform.

import { spawn } from "node:child_process";
import { existsSync, realpathSync } from "node:fs";
import { dirname, resolve } from "node:path";
import { fileURLToPath } from "node:url";

// No runtime Node-version guard lives here on purpose: this launcher is an
// extensionless ESM file, which Node < 20 cannot even load (it throws
// ERR_UNKNOWN_FILE_EXTENSION before any code runs), so a guard here could never
// fire for the versions it would target. The Node >= 20 floor is enforced at
// install time by `.npmrc` engine-strict, and `qmd doctor` reports the running
// Node version against that floor.

// Resolve symlinks so global installs (npm link / npm install -g) can find
// the actual package directory instead of the global bin directory.
const self = realpathSync(fileURLToPath(import.meta.url));
const pkgDir = resolve(dirname(self), "..");
const jsEntry = resolve(pkgDir, "dist/cli/qmd.js");
const tsEntry = resolve(pkgDir, "src/cli/qmd.ts");

// libggml-metal on macOS uses "residency sets" to keep allocated model memory
// resident across inference requests (180-second keep_alive timer). The
// process-static device destructor that runs during libc exit() asserts the
// residency set is empty (ggml-org/llama.cpp#22593); the keep_alive hasn't
// expired by exit, so the assertion fails and ggml_abort dumps a multi-kB
// stack trace to stderr even when the user-visible results were already
// emitted correctly. No JS-side dispose can prevent it because the static
// destructor runs in __cxa_finalize_ranges, after every JS-reachable cleanup.
//
// For QMD's short-lived CLI workflow, residency sets provide no observable
// performance benefit (subsequent requests don't reuse the warm mapping —
// measured: identical wall time with and without on M3 Pro), so disable them
// by default on darwin. The env var must be set BEFORE the native llama.cpp
// binding loads, which is why it lives here in the launcher rather than in
// the JS entry point. Opt back in with QMD_METAL_KEEP_RESIDENCY=1 if you
// run long-lived qmd processes or are triaging an upstream Metal teardown fix.
if (process.platform === "darwin" && process.env.QMD_METAL_KEEP_RESIDENCY !== "1") {
  process.env.GGML_METAL_NO_RESIDENCY = process.env.GGML_METAL_NO_RESIDENCY || "1";
}

// --- Corporate-proxy / TLS bootstrap ---------------------------------------
// qmd's own fetch and node-llama-cpp's model downloader (-> ipull -> Node fetch)
// use Node's trust store, which ignores curl's --cacert bundle. Behind a
// TLS-intercepting proxy this surfaces as UNABLE_TO_GET_ISSUER_CERT_LOCALLY.
// Node reads NODE_EXTRA_CA_CERTS once at startup, so we resolve a CA bundle here
// and set it on the CHILD's env before spawn — covering both qmd and ipull
// without a re-exec. No org-specific path is baked into the repo: supply it via
// QMD_CA_BUNDLE (or the standard NODE_EXTRA_CA_CERTS / SSL_CERT_FILE). The
// qmd-setup skill prompts the agent, which knows the environment, to provide it.
//
// `--insecure-tls` is a launcher-level escape hatch (consumed here, never
// forwarded to the CLI) that disables TLS verification for this invocation only.
// Consume `--insecure-tls` wherever it appears as an option (so `qmd pull --insecure-tls`
// and `qmd --insecure-tls pull` both work), but stop at a `--` end-of-options marker so a
// literal value can still be passed through, e.g. `qmd search -- --insecure-tls`.
const rawArgs = process.argv.slice(2);
let insecureTls = false;
let endOfOptions = false;
const forwardArgs = [];
for (const a of rawArgs) {
  if (!endOfOptions && a === "--") endOfOptions = true;
  else if (!endOfOptions && a === "--insecure-tls") { insecureTls = true; continue; }
  forwardArgs.push(a);
}

const childEnv = { ...process.env };
if (!childEnv.NODE_EXTRA_CA_CERTS) {
  const caBundle = childEnv.QMD_CA_BUNDLE || childEnv.SSL_CERT_FILE;
  if (caBundle && existsSync(caBundle)) {
    childEnv.NODE_EXTRA_CA_CERTS = caBundle;
  }
}
if (insecureTls) {
  childEnv.NODE_TLS_REJECT_UNAUTHORIZED = "0";
  console.error(
    "qmd: --insecure-tls set — TLS certificate verification is DISABLED for this run. " +
    "Prefer a CA bundle via QMD_CA_BUNDLE/NODE_EXTRA_CA_CERTS where possible."
  );
}

// In published packages, bin/qmd must run dist/. In a git checkout, however,
// dist/ is often ignored and can be stale after git reset or branch switches.
// Prefer source mode only for checkouts so ./bin/qmd reflects the checked-out
// source without changing packaged/runtime behavior.
//
// Critical: source-mode detection must NOT trigger when a package manager
// installed us. `npm install -g .` copies the entire working tree — including
// .git/, package-lock.json, src/, and even node_modules/ — into
// <prefix>/node_modules/@tobilu/qmd/, so .git and a lockfile being present is
// not a reliable "this is a working tree" signal. What IS reliable: a
// package-manager install always lands the package directory inside a
// `node_modules/` segment; a bare working-tree checkout (with `npm link` or a
// direct path invocation) does not. Gate source mode on that. Allow
// QMD_SOURCE_MODE=1 / =0 as an explicit override for the rare case where the
// heuristic disagrees with the user.
const sourceOverride = process.env.QMD_SOURCE_MODE;
const looksInstalled = pkgDir.split("/").includes("node_modules");
const sourceAllowed = sourceOverride === "1"
  || (sourceOverride !== "0" && !looksInstalled);

let useSourceMode = false;
let sourceArgs = [];

if (sourceAllowed && existsSync(resolve(pkgDir, ".git")) && existsSync(tsEntry)) {
  // Source mode runs the TypeScript entry via tsx under Node.
  const tsxEntry = resolve(pkgDir, "node_modules/tsx/dist/cli.mjs");
  if (existsSync(tsxEntry)) {
    useSourceMode = true;
    sourceArgs = [tsxEntry, tsEntry, ...forwardArgs];
  }
}

if (!useSourceMode && !existsSync(jsEntry)) {
  console.error(`qmd is not built: missing ${jsEntry}`);
  console.error("Run: npm install && npm run build");
  console.error("After building, run: qmd doctor");
  process.exit(1);
}

// qmd-gd is Node-only: always launch under `node`. Source mode runs the
// TypeScript entry via tsx; dist mode runs the compiled JS directly.
const runner = "node";
const args = useSourceMode ? sourceArgs : [jsEntry, ...forwardArgs];

const child = spawn(runner, args, {
  stdio: "inherit",
  env: childEnv,
});

child.on("exit", (code, signal) => {
  if (signal) {
    process.kill(process.pid, signal);
  } else {
    process.exit(code ?? 0);
  }
});

child.on("error", (err) => {
  console.error(`qmd: failed to launch ${runner}: ${err.message}`);
  process.exit(1);
});
