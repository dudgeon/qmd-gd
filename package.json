{
  "name": "qmd-gd",
  "version": "2.6.3",
  "description": "Query Markup Documents (qmd-gd fork) - on-device BM25 + vector search for locked-down agent environments; no MCP, no local generative models",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "qmd": "bin/qmd"
  },
  "files": [
    "bin/",
    "dist/",
    "models/",
    ".claude/skills/",
    ".claude/agents/",
    "scripts/build.mjs",
    "scripts/test-all.mjs",
    "scripts/install.sh",
    "docs/adr/",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "node scripts/test-all.mjs",
    "test:types": "node ./node_modules/typescript/bin/tsc -p tsconfig.build.json --noEmit",
    "test:node": "node ./node_modules/vitest/vitest.mjs run --reporter=verbose --testTimeout 60000",
    "test:unit": "CI=true node ./node_modules/vitest/vitest.mjs run --reporter=verbose --testTimeout 60000 test/",
    "qmd": "tsx src/cli/qmd.ts",
    "search": "tsx src/cli/qmd.ts search",
    "vsearch": "tsx src/cli/qmd.ts vsearch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dudgeon/qmd-gd.git"
  },
  "homepage": "https://github.com/dudgeon/qmd-gd#readme",
  "bugs": {
    "url": "https://github.com/dudgeon/qmd-gd/issues"
  },
  "dependencies": {
    "better-sqlite3": "12.10.0",
    "fast-glob": "3.3.3",
    "node-llama-cpp": "3.18.1",
    "picomatch": "4.0.4",
    "sqlite-vec": "0.1.9",
    "yaml": "2.9.0",
    "zod": "4.2.1"
  },
  "optionalDependencies": {
    "sqlite-vec-darwin-arm64": "0.1.9",
    "sqlite-vec-darwin-x64": "0.1.9",
    "sqlite-vec-linux-arm64": "0.1.9",
    "sqlite-vec-linux-x64": "0.1.9",
    "sqlite-vec-windows-x64": "0.1.9"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "tsx": "4.21.0",
    "typescript": "^5.9.3",
    "vitest": "3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "node-llama-cpp"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "markdown",
    "search",
    "fts",
    "full-text-search",
    "vector",
    "semantic-search",
    "sqlite",
    "bm25",
    "embeddings",
    "rag",
    "knowledge-base",
    "local-ai"
  ],
  "author": "Tobi Lutke <tobi@lutke.com>",
  "license": "MIT"
}
